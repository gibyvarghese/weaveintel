{
  "name": "@weaveintel/upgrade",
  "version": "0.2.0",
  "description": "Self-upgrade engine primitives — priority banding for a reconcile review queue, pre-upgrade database snapshots, and a structured id-keyed three-way merge.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "license": "MIT",
  "dependencies": {
    "@weaveintel/encryption": "^0.1.1",
    "semver": "^7.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.6",
    "better-sqlite3": "^11.8.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/semver": "^7.5.8"
  }
}
