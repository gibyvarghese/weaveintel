  "version": "0.1.0",
  "description": "Market data MCP tool server — quotes, OHLCV, fundamentals, filings, insiders, options, macro",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
