{
  "name": "@weaveintel/notifications",
  "version": "0.1.1",
  "description": "Notification channels, dispatcher, and target store for the weaveIntel platform. Supports webhook, web-push, APNs, and FCM.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@weaveintel/core": "^0.1.1",
    "@weaveintel/resilience": "^0.1.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.6",
    "@testcontainers/postgresql": "^11.0.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ]
}
