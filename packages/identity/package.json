{
  "name": "@weaveintel/identity",
  "version": "0.1.1",
  "description": "Identity, delegation, and access-control runtime",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./oauth": {
      "import": "./dist/oauth/index.js",
      "types": "./dist/oauth/index.d.ts",
      "default": "./dist/oauth/index.js"
    },
    "./tenancy": {
      "import": "./dist/tenancy/index.js",
      "types": "./dist/tenancy/index.d.ts",
      "default": "./dist/tenancy/index.js"
    },
    "./scope": {
      "import": "./dist/scope/index.js",
      "types": "./dist/scope/index.d.ts",
      "default": "./dist/scope/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@weaveintel/core": "^0.1.1",
    "@weaveintel/persistence": "^0.1.1"
  },
  "devDependencies": {
    "vitest": "^3.2.6",
    "better-sqlite3": "^11.8.0",
    "@types/better-sqlite3": "^7.6.11",
    "pg": "^8.13.0",
    "@types/pg": "^8.11.0",
    "@testcontainers/postgresql": "^11.0.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ]
}
