{
  "name": "@weaveintel/persistence",
  "version": "0.1.2",
  "description": "Shared persistence contracts and adapter scaffolding for weaveIntel runtimes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "license": "MIT",
  "dependencies": {
    "@weaveintel/core": "^0.1.1",
    "@weaveintel/memory": "^0.1.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.0.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0",
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
