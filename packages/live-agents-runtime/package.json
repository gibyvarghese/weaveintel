{
  "name": "@weaveintel/live-agents-runtime",
  "version": "0.0.1",
  "description": "Generic, DB-driven runtime atop @weaveintel/live-agents — handler registry + built-in plugins (agentic.react, deterministic.forward).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@weaveintel/a2a": "^0.0.1",
    "@weaveintel/agents": "^0.0.1",
    "@weaveintel/core": "^0.0.1",
    "@weaveintel/live-agents": "^0.0.1",
    "@weaveintel/tools": "^0.0.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
