{
  "name": "@weaveintel/cost-governor",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sqlite": {
      "import": "./dist/stores/sqlite-index.js",
      "types": "./dist/stores/sqlite-index.d.ts",
      "default": "./dist/stores/sqlite-index.js"
    },
    "./postgres": {
      "import": "./dist/stores/postgres-index.js",
      "types": "./dist/stores/postgres-index.d.ts",
      "default": "./dist/stores/postgres-index.js"
    },
    "./mongodb": {
      "import": "./dist/stores/mongodb-index.js",
      "types": "./dist/stores/mongodb-index.d.ts",
      "default": "./dist/stores/mongodb-index.js"
    },
    "./redis": {
      "import": "./dist/stores/redis-index.js",
      "types": "./dist/stores/redis-index.d.ts",
      "default": "./dist/stores/redis-index.js"
    },
    "./dynamodb": {
      "import": "./dist/stores/dynamodb-index.js",
      "types": "./dist/stores/dynamodb-index.d.ts",
      "default": "./dist/stores/dynamodb-index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@weaveintel/core": "*",
    "@weaveintel/tools": "*"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.10.0",
    "pg": "^8.13.1",
    "mongodb": "^6.16.0",
    "redis": "^4.7.0",
    "@aws-sdk/client-dynamodb": "^3.810.0",
    "@aws-sdk/lib-dynamodb": "^3.810.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "@aws-sdk/client-dynamodb": {
      "optional": true
    },
    "@aws-sdk/lib-dynamodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.6",
    "better-sqlite3": "^11.10.0",
    "pg": "^8.13.1",
    "mongodb": "^6.16.0",
    "redis": "^4.7.0",
    "@aws-sdk/client-dynamodb": "^3.810.0",
    "@aws-sdk/lib-dynamodb": "^3.810.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
