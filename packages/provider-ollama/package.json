{
  "name": "@weaveintel/provider-ollama",
  "version": "0.0.1",
  "description": "Ollama provider for weaveIntel — local LLMs (Llama, Mistral, Qwen, Phi, Gemma, DeepSeek, etc.)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@weaveintel/core": "*",
    "@weaveintel/models": "*",
    "@weaveintel/tool-schema": "*"
  },
  "license": "MIT"
}
