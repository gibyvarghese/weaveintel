{
  "name": "@weaveintel/voice",
  "version": "0.0.1",
  "description": "Production-grade voice agent pipeline for WeaveIntel — STT, TTS, WebSocket session management and full parity with text agents",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
