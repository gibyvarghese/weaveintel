  },
  "dependencies": {
    "@weaveintel/core": "*",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
