{
  "name": "@weaveintel/memory",
  "version": "0.1.2",
  "description": "Memory implementations — conversation, semantic, entity",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.810.0",
    "@aws-sdk/lib-dynamodb": "^3.810.0",
    "@weaveintel/core": "^0.1.1",
    "@weaveintel/human-tasks": "^0.1.1",
    "better-sqlite3": "^11.10.0",
    "mongodb": "^6.16.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6",
    "@testcontainers/postgresql": "^11.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ]
}
