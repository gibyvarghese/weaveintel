{
  "name": "@weaveintel/weaveintel",
  "version": "0.0.1",
  "description": "Meta-package: the curated entry point most adopters need. Re-exports the eight packages that make up the weaveIntel ambient runtime.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "license": "MIT",
  "dependencies": {
    "@weaveintel/agents": "^0.0.1",
    "@weaveintel/core": "^0.0.1",
    "@weaveintel/observability": "^0.0.1",
    "@weaveintel/persistence": "^0.0.1",
    "@weaveintel/resilience": "^0.0.1",
    "@weaveintel/tools": "^0.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
