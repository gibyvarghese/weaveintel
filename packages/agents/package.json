{
  "name": "@weaveintel/agents",
  "version": "0.0.1",
  "description": "Agent runtime — tool-calling loop, planner-executor, hierarchical supervisor-worker",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./recipes": {
      "import": "./dist/recipes/index.js",
      "types": "./dist/recipes/index.d.ts",
      "default": "./dist/recipes/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@weaveintel/core": "^0.0.1",
    "@weaveintel/models": "^0.0.1",
    "@weaveintel/evals": "^0.0.1",
    "@weaveintel/prompts": "^0.0.1",
    "@weaveintel/human-tasks": "^0.0.1",
    "@weaveintel/a2a": "^0.0.1",
    "@weaveintel/graph": "^0.0.1",
    "@weaveintel/cost-governor": "^0.0.1",
    "@weaveintel/compliance": "^0.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ]
}
