{
  "name": "@weaveintel/provider-google",
  "version": "0.0.1",
  "description": "Google Gemini provider for weaveIntel — chat, tool use, vision, streaming",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@weaveintel/core": "^0.0.1",
    "@weaveintel/resilience": "^0.0.1",
    "@weaveintel/tools": "^0.0.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
