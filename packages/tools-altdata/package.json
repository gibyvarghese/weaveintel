{
  "name": "@weaveintel/tools-altdata",
  "version": "0.1.0",
  "description": "Alternative data MCP tool server — Google Trends, ESG scores, supply chain exposure",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@weaveintel/core": "*",
    "@weaveintel/mcp-server": "*",
    "@weaveintel/tools": "*"
  },
  "devDependencies": {
    "@weaveintel/mcp-client": "*",
    "@weaveintel/testing": "*",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
