{
  "name": "@weaveintel/live-agents",
  "version": "0.0.1",
  "description": "Persistent autonomous agent primitives for weaveIntel",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.810.0",
    "@aws-sdk/lib-dynamodb": "^3.810.0",
    "@weaveintel/agents": "^0.0.1",
    "@weaveintel/core": "^0.0.1",
    "@weaveintel/identity": "^0.0.1",
    "@weaveintel/mcp-client": "^0.0.1",
    "@weaveintel/memory": "^0.0.1",
    "@weaveintel/observability": "^0.0.1",
    "@weaveintel/tools": "^0.0.1",
    "better-sqlite3": "^11.10.0",
    "mongodb": "^6.16.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
