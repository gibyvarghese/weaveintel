{
  "name": "@weaveintel/i18n",
  "version": "0.0.1",
  "type": "module",
  "description": "Framework-agnostic internationalisation core for weaveIntel — pure, dependency-free message catalogs, an ICU-subset t() (interpolation + plurals), and BCP-47 locale fallback.",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
