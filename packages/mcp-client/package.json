{
  "name": "@weaveintel/mcp-client",
  "version": "0.0.1",
  "description": "MCP client — connect to MCP servers and expose their tools",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
