{
  "extends": "./tsconfig.base.json",
  "include": [
    "examples/**/*.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "isolatedModules": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false,
    "strict": false,
    "noPropertyAccessFromIndexSignature": false,
    "skipLibCheck": true
  }
}
