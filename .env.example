# ─── weaveIntel Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── OpenAI ───────────────────────────────────────────────────
# Required for @weaveintel/provider-openai and examples that use OpenAI models.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Override the default OpenAI base URL (e.g. for Azure OpenAI or a proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: OpenAI organization ID
# OPENAI_ORG_ID=org-your-org-id-here

# ─── Future Providers ────────────────────────────────────────
# Uncomment and fill in when adding additional provider packages.

# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# AZURE_OPENAI_API_KEY=your-azure-openai-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# GOOGLE_AI_API_KEY=your-google-ai-key-here
# COHERE_API_KEY=your-cohere-key-here

# ─── Observability (optional) ────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=weaveintel

# ─── General ─────────────────────────────────────────────────
# NODE_ENV=development
# LOG_LEVEL=debug

# ─── GeneWeave Security ──────────────────────────────────────
# Required to encrypt/decrypt stored credentials in the GeneWeave vault.
# Use a strong random secret and keep it stable across restarts.
# VAULT_KEY=replace-with-a-strong-random-secret

# ─── ServiceNow ──────────────────────────────────────────────
# Required for ServiceNow integration tests and enterprise tools.
# SERVICENOW_INSTANCE=dev12345
# SERVICENOW_CLIENT_ID=your-oauth-client-id
# SERVICENOW_CLIENT_SECRET=your-oauth-client-secret
# SERVICENOW_USERNAME=admin
# SERVICENOW_PASSWORD=your-password

# ─── Tool Connector OAuth Apps (optional) ────────────────────
# Used by examples/59-oauth-tool-connection-examples.ts
# OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
# OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# OAUTH_MICROSOFT_CLIENT_ID=your-microsoft-client-id
# OAUTH_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# OAUTH_MICROSOFT_TENANT=common
# OAUTH_DROPBOX_CLIENT_ID=your-dropbox-client-id
# OAUTH_DROPBOX_CLIENT_SECRET=your-dropbox-client-secret
# OAUTH_SLACK_CLIENT_ID=your-slack-client-id
# OAUTH_SLACK_CLIENT_SECRET=your-slack-client-secret

# ─── Stats NZ — Aotearoa Data Explorer API ───────────────────
# Required for the statsnz_* tools (statsnz_list_dataflows, statsnz_get_data, etc.)
# and the standalone statsnz-mcp-server.
# Subscribe at: https://portal.apis.stats.govt.nz/how-to-subscribe
# STATSNZ_API_KEY=your-subscription-key-here

# ─── Scientific Validation Literature APIs ────────────────────
# Required for semanticscholar_search in scientific validation workflows.
# Get a key at: https://www.semanticscholar.org/product/api
# SEMANTIC_SCHOLAR_API_KEY=s2k-your-semantic-scholar-api-key
