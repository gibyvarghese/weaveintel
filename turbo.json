{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json", "tsconfig.*.json"],
      "outputs": ["dist/**", "*.tsbuildinfo"],
      "env": ["NODE_ENV"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "test/**", "package.json", "tsconfig.json", "tsconfig.*.json"],
      "env": ["NODE_ENV", "CI"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json", "tsconfig.*.json"],
      "outputs": ["*.tsbuildinfo"],
      "env": ["NODE_ENV"]
    },
    "lint": {},
    "clean": {
      "cache": false
    }
  }
}
