{
  "expo": {
    "name": "geneWeave",
    "slug": "geneweave-mobile",
    "scheme": "geneweave",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.geneweave.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock geneWeave."
      }
    },
    "android": {
      "package": "com.geneweave.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock geneWeave."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
