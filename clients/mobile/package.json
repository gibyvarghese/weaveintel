{
  "name": "geneweave-mobile",
  "version": "0.0.1",
  "private": true,
  "description": "geneWeave mobile app (React Native + Expo, Expo Router, new architecture). A pure logic layer (src/lib) is unit-tested in Node; the native view layer (src/native) and Expo Router screens (app/) are device-gated and installed via `npx expo install` on a dev machine.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck:lib": "tsc -p src/lib/tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@expo-google-fonts/dm-mono": "^0.2.3",
    "@expo-google-fonts/fraunces": "^0.2.3",
    "@expo-google-fonts/plus-jakarta-sans": "^0.2.3",
    "@geneweave/api-client": "*",
    "@geneweave/tokens": "*",
    "@tanstack/react-query": "^5.62.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.2",
    "expo-font": "~13.0.0",
    "expo-linking": "~7.0.0",
    "expo-local-authentication": "~15.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
