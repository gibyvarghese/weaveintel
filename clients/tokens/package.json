{
  "name": "@weaveintel/tokens",
  "version": "0.0.1",
  "description": "A brand-neutral theming engine — token schema, colour maths (WCAG-AA), a CSS-variable transform, and per-tenant white-label — that takes your palette as input.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
