{
  "name": "@geneweave/api-client",
  "version": "0.0.1",
  "description": "geneWeave typed API client — bearer-token /api/me surface over @weaveintel/client (runs, catalog, tasks, reminders, memories, devices, notifications, conversations). No React Native imports.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@weaveintel/client": "^0.0.1",
    "@weaveintel/core": "^0.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "license": "MIT"
}
