    {
      "key": "baseUrl",
      "value": "http://localhost:3500",
      "type": "string"
    },
    {
      "key": "email",
      "value": "a2a-postman@weaveintel.test",
      "type": "string"
    },
    {
      "key": "password",
      "value": "Postman1!",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "csvBase64",
      "value": "",
      "type": "string",
      "description": "Base64-encoded CSV file. Run: base64 -i sales.csv | tr -d '\\n' and paste the result here."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (saves token automatically)",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "auth-login-test",
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "const tok = r.token || r.accessToken;",
                  "if (tok) {",
                  "    pm.collectionVariables.set('token', tok);",
                  "    pm.test('Token saved to collection variable', function() {",
                  "        pm.expect(tok).to.be.a('string').with.length.above(10);",
                  "    });",
                  "} else {",
                  "    pm.test('Login failed - no token in response', function() {",
                  "        pm.expect.fail('No token returned: ' + JSON.stringify(r));",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "token"
              ]
            }
          },
          "response": []
        }
      ]
    },
