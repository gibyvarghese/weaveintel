    {
      "name": "A2A",
      "item": [
        {
          "name": "Agent Card",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "agent-card-test",
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function() { pm.response.to.have.status(200); });",
                  "const card = pm.response.json();",
                  "pm.test('Has skills array', function() {",
                  "    pm.expect(card.skills).to.be.an('array').with.length.above(0);",
                  "});",
                  "console.log('Skills:', card.skills.map(s => s.id).join(', '));",
                  "console.log('Agent name:', card.name, '| version:', card.version);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/.well-known/agent-card.json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ".well-known",
                "agent-card.json"
              ]
            },
            "description": "Returns the public Agent Card listing all DB-backed skills. No auth required."
          },
          "response": []
        },
        {
          "name": "SendMessage - plain text (smoke test)",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "plain-text-test",
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function() { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('No JSON-RPC error', function() { pm.expect(body.error).to.be.undefined; });",
                  "const task = body.result;",
                  "pm.test('Task completed', function() {",
                  "    pm.expect(task.status.state).to.eql('TASK_STATE_COMPLETED');",
                  "});",
                  "const text = task && task.artifacts && task.artifacts[0] && task.artifacts[0].parts && task.artifacts[0].parts[0] ? task.artifacts[0].parts[0].text : '';",
                  "pm.test('Response has content', function() { pm.expect(text.length).to.be.above(5); });",
                  "console.log('Resolved mode:', task && task.metadata ? task.metadata.resolvedMode : 'n/a');",
                  "console.log('Latency ms:', task && task.metadata ? task.metadata.latencyMs : 'n/a');",
                  "console.log('Response:', text.slice(0, 300));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": \"req-001\",\n    \"method\": \"SendMessage\",\n    \"params\": {\n        \"message\": {\n            \"role\": \"user\",\n            \"parts\": [\n                {\n                    \"text\": \"What is the capital of France? One sentence only.\"\n                }\n            ]\n        },\n        \"metadata\": {\n            \"mode\": \"agent\"\n        }\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/a2a",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "a2a"
              ]
            },
            "description": "Minimal A2A call with plain text. Use this to verify the endpoint and auth are working before sending files.\n\nExpected response:\n  result.status.state = TASK_STATE_COMPLETED\n  result.artifacts[0].parts[0].text = answer text\n  result.metadata.resolvedMode = \"agent\""
          },
          "response": []
        },
        {
          "name": "SendMessage - CSV analysis (agent mode)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "id": "csv-prerequest",
                "type": "text/javascript",
                "exec": [
                  "// If csvBase64 collection variable is not set, use a small demo CSV.",
                  "// To use your real file:",
                  "//   macOS: base64 -i sales.csv | tr -d '\\n'",
                  "//   Linux: base64 -w 0 sales.csv",
                  "// Paste the result into the collection variable 'csvBase64'.",
                  "if (!pm.collectionVariables.get('csvBase64')) {",
                  "    var demoCSV = 'date,region,product,units,unit_price,revenue,cost,profit\\n' +",
                  "        '2024-01-01,North,Widget A,10,9.99,99.90,60.00,39.90\\n' +",
                  "        '2024-01-02,South,Widget B,5,19.99,99.95,55.00,44.95\\n' +",
                  "        '2024-01-03,East,Widget A,8,9.99,79.92,48.00,31.92\\n' +",
                  "        '2024-01-04,West,Widget C,12,14.99,179.88,96.00,83.88\\n' +",
                  "        '2024-01-05,North,Widget B,3,19.99,59.97,33.00,26.97';",
                  "    pm.collectionVariables.set('csvBase64', btoa(demoCSV));",
                  "    console.log('Using demo CSV (5 rows). Set csvBase64 variable to use your own file.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "id": "csv-test",
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function() { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('No JSON-RPC error', function() { pm.expect(body.error).to.be.undefined; });",
                  "const task = body.result;",
                  "pm.test('Task completed', function() {",
                  "    pm.expect(task.status.state).to.eql('TASK_STATE_COMPLETED');",
                  "});",
                  "const text = task && task.artifacts && task.artifacts[0] && task.artifacts[0].parts && task.artifacts[0].parts[0] ? task.artifacts[0].parts[0].text : '';",
                  "pm.test('Response has content', function() { pm.expect(text.length).to.be.above(50); });",
                  "var hasCseEvidence = /rows:|dtype|\\d+\\.\\d{2}|region|revenue/i.test(text);",
                  "pm.test('CSE evidence in response', function() { pm.expect(hasCseEvidence).to.be.true; });",
                  "console.log('Active skills:', JSON.stringify(task && task.metadata ? task.metadata.activeSkills : []));",
                  "console.log('Resolved mode:', task && task.metadata ? task.metadata.resolvedMode : 'n/a');",
                  "console.log('Attachments:', task && task.metadata ? task.metadata.attachmentCount : 'n/a');",
                  "console.log('Latency ms:', task && task.metadata ? task.metadata.latencyMs : 'n/a');",
                  "console.log('Response (first 600 chars):', text.slice(0, 600));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": \"req-csv-001\",\n    \"method\": \"SendMessage\",\n    \"params\": {\n        \"message\": {\n            \"role\": \"user\",\n            \"parts\": [\n                {\n                    \"text\": \"I have uploaded a sales dataset as a CSV file. Please analyse it using Python code execution. Write and run Python code to: (1) Load the CSV and show basic stats (rows, columns, dtypes). (2) Compute total revenue and average unit price by region, sorted descending. (3) Show top 5 products by total revenue. After each code block, explain the key insight for a sales manager.\"\n                },\n                {\n                    \"raw\": \"{{csvBase64}}\",\n                    \"mediaType\": \"text/csv\",\n                    \"filename\": \"sales.csv\"\n                }\n            ]\n        },\n        \"metadata\": {\n            \"mode\": \"agent\"\n        }\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/a2a",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "a2a"
              ]
            },
            "description": "Sends a CSV file as a base64-encoded FilePart and asks for Python-executed analysis.\n\nThe `raw` field inside the FilePart part holds the base64 string of your CSV.\n\nSetting up the CSV:\n  1. Encode your file:\n       macOS: base64 -i sales.csv | tr -d '\\n'\n       Linux: base64 -w 0 sales.csv\n  2. Copy the output and paste it into the collection variable 'csvBase64'.\n  3. If csvBase64 is empty, the Pre-request Script fills in a small 5-row demo CSV automatically.\n\nExpected response:\n  result.status.state            = TASK_STATE_COMPLETED\n  result.metadata.resolvedMode   = \"agent\"\n  result.metadata.activeSkills   = [\"skill-data-analysis-execution\"]\n  result.metadata.attachmentCount = 1\n  result.artifacts[0].parts[0].text = Python-computed analysis"
          },
          "response": []
        },
        {
          "name": "SendMessage - supervisor orchestration with CSV",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "id": "sup-prerequest",
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('csvBase64')) {",
                  "    var demoCSV = 'date,region,product,units,unit_price,revenue,cost,profit\\n' +",
                  "        '2024-01-01,North,Widget A,10,9.99,99.90,60.00,39.90\\n' +",
                  "        '2024-01-02,South,Widget B,5,19.99,99.95,55.00,44.95\\n' +",
                  "        '2024-01-03,East,Widget A,8,9.99,79.92,48.00,31.92';",
                  "    pm.collectionVariables.set('csvBase64', btoa(demoCSV));",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "id": "sup-test",
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function() { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('No JSON-RPC error', function() { pm.expect(body.error).to.be.undefined; });",
                  "const task = body.result;",
                  "pm.test('Task completed', function() {",
                  "    pm.expect(task.status.state).to.eql('TASK_STATE_COMPLETED');",
                  "});",
                  "var mode = task && task.metadata ? task.metadata.resolvedMode : 'n/a';",
                  "console.log('Resolved mode:', mode);",
                  "console.log('Downgrade reason:', task && task.metadata ? task.metadata.downgradeReason : 'none');",
                  "// Note: if the caller lacks agents:delegate permission, mode will be downgraded to agent",
                  "console.log('Active skills:', JSON.stringify(task && task.metadata ? task.metadata.activeSkills : []));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": \"req-sup-001\",\n    \"method\": \"SendMessage\",\n    \"params\": {\n        \"message\": {\n            \"role\": \"user\",\n            \"parts\": [\n                {\n                    \"text\": \"I have uploaded a sales dataset. Use the code_executor worker to run Python analysis on it, then have the analyst worker produce at least 3 business insights.\"\n                },\n                {\n                    \"raw\": \"{{csvBase64}}\",\n                    \"mediaType\": \"text/csv\",\n                    \"filename\": \"sales.csv\"\n                }\n            ]\n        },\n        \"metadata\": {\n            \"mode\": \"supervisor\"\n        }\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/a2a",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "a2a"
              ]
            },
            "description": "Routes to the supervisor-orchestration skill which delegates to code_executor + analyst workers.\n\nNote: if the calling user lacks the agents:delegate RBAC permission, the mode is automatically downgraded to agent and metadata.downgradeReason will explain why."
          },
          "response": []
        },
        {
          "name": "SendMessage - explicit Python execution (no file)",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "code-exec-test",
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function() { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('No JSON-RPC error', function() { pm.expect(body.error).to.be.undefined; });",
                  "const task = body.result;",
                  "pm.test('Task completed', function() {",
                  "    pm.expect(task.status.state).to.eql('TASK_STATE_COMPLETED');",
                  "});",
                  "const text = task && task.artifacts && task.artifacts[0] && task.artifacts[0].parts && task.artifacts[0].parts[0] ? task.artifacts[0].parts[0].text : '';",
                  "pm.test('Contains numeric output', function() { pm.expect(/\\d+\\.\\d{2}/.test(text)).to.be.true; });",
                  "console.log('Response:', text.slice(0, 400));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": \"req-code-001\",\n    \"method\": \"SendMessage\",\n    \"params\": {\n        \"message\": {\n            \"role\": \"user\",\n            \"parts\": [\n                {\n                    \"text\": \"Please run this Python code and show me the output:\\n\\n```python\\nimport statistics\\ndata = [95.7, 81.35, 94.74, 83.26, 71.15]\\nprint(f'Count: {len(data)}')\\nprint(f'Mean:  {statistics.mean(data):.2f}')\\nprint(f'Std:   {statistics.stdev(data):.2f}')\\nprint(f'Min:   {min(data):.2f}')\\nprint(f'Max:   {max(data):.2f}')\\n```\\n\\nThen explain what these stats indicate about the price distribution.\"\n                }\n            ]\n        },\n        \"metadata\": {\n            \"mode\": \"agent\"\n        }\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/a2a",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "a2a"
              ]
            },
            "description": "Asks the agent to execute a Python snippet with no file attached. Use this to verify CSE (code sandbox) is working independently of file upload."
          },
          "response": []
        }
      ]
    }
  ]
