{
  "name": "@weaveintel/geneweave-api",
  "version": "1.0.0",
  "description": "geneWeave API — server, database, chat engine and all backend services for the geneWeave platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:api": "vitest run src/api.test.ts",
    "test:e2e": "npx playwright test --config playwright.config.ts",
    "sv:eval": "npx tsx src/features/scientific-validation/evals/run-corpus.ts",
    "sv:cost-gate": "npx tsx src/features/scientific-validation/evals/cost-gate.ts"
  },
  "dependencies": {
    "@weaveintel/agents": "*",
    "@weaveintel/core": "*",
    "@weaveintel/evals": "*",
    "@weaveintel/guardrails": "*",
    "@weaveintel/observability": "*",
    "@weaveintel/redaction": "*",
    "@weaveintel/workflows": "*",
    "@weaveintel/triggers": "*",
    "@weaveintel/capability-packs": "*",
    "@weaveintel/cost-governor": "*",
    "@weaveintel/encryption": "*",
    "@weaveintel/human-tasks": "*",
    "@weaveintel/notifications": "*",
    "@weaveintel/contracts": "*",
    "@weaveintel/prompts": "*",
    "@weaveintel/skills": "*",
    "@weaveintel/routing": "*",
    "@weaveintel/oauth": "*",
    "@weaveintel/cache": "*",
    "@weaveintel/identity": "*",
    "@weaveintel/memory": "*",
    "@weaveintel/mcp-statsnz": "*",
    "@weaveintel/mcp-server": "*",
    "@weaveintel/tools-browser": "*",
    "@weaveintel/tools-enterprise": "*",
    "@weaveintel/tools-http": "*",
    "@weaveintel/tools-search": "*",
    "@weaveintel/tools-time": "*",
    "@weaveintel/ui-primitives": "*",
    "@weaveintel/devtools": "*",
    "@weaveintel/sandbox": "*",
    "@weaveintel/recipes": "*",
    "@weaveintel/a2a": "*",
    "@weaveintel/replay": "*",
    "@weaveintel/tenancy": "*",
    "@weaveintel/reliability": "*",
    "@weaveintel/durability": "*",
    "@weaveintel/persistence": "*",
    "@weaveintel/resilience": "*",
    "@weaveintel/triggers": "*",
    "@weaveintel/models": "*",
    "@weaveintel/tools": "*",
    "@weaveintel/collaboration": "*",
    "@weaveintel/live-agents": "*",
    "@weaveintel/live-agents-runtime": "*",
    "@weaveintel/live-agents-trace-tools": "*",
    "better-sqlite3": "^11.9.1",
    "@weaveintel/geneweave-ui": "*"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@weaveintel/testing": "*"
  },
  "peerDependencies": {
    "@weaveintel/provider-anthropic": "*",
    "@weaveintel/provider-openai": "*",
    "@weaveintel/provider-google": "*",
    "@weaveintel/provider-ollama": "*",
    "@weaveintel/provider-llamacpp": "*"
  },
  "peerDependenciesMeta": {
    "@weaveintel/provider-openai": {
      "optional": true
    },
    "@weaveintel/provider-anthropic": {
      "optional": true
    },
    "@weaveintel/provider-google": {
      "optional": true
    },
    "@weaveintel/provider-ollama": {
      "optional": true
    },
    "@weaveintel/provider-llamacpp": {
      "optional": true
    }
  },
  "license": "MIT"
}
