{
  "name": "@weaveintel/geneweave",
  "version": "1.0.0",
  "description": "geneWeave — AI chatbot application with streaming, auth, observability dashboard, built on weaveIntel",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:api": "vitest run src/api.test.ts",
    "test:e2e": "npx playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@weaveintel/agents": "*",
    "@weaveintel/core": "*",
    "@weaveintel/evals": "*",
    "@weaveintel/guardrails": "*",
    "@weaveintel/observability": "*",
    "@weaveintel/redaction": "*",
    "@weaveintel/workflows": "*",
    "@weaveintel/human-tasks": "*",
    "@weaveintel/contracts": "*",
    "@weaveintel/prompts": "*",
    "@weaveintel/skills": "*",
    "@weaveintel/routing": "*",
    "@weaveintel/oauth": "*",
    "@weaveintel/cache": "*",
    "@weaveintel/identity": "*",
    "@weaveintel/memory": "*",
    "@weaveintel/mcp-statsnz": "*",
    "@weaveintel/tools-browser": "*",
    "@weaveintel/tools-enterprise": "*",
    "@weaveintel/tools-http": "*",
    "@weaveintel/tools-search": "*",
    "@weaveintel/tools-time": "*",
    "@weaveintel/ui-primitives": "*",
    "@weaveintel/devtools": "*",
    "@weaveintel/sandbox": "*",
    "@weaveintel/recipes": "*",
    "better-sqlite3": "^11.9.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13"
  },
  "peerDependencies": {
    "@weaveintel/provider-anthropic": "*",
    "@weaveintel/provider-openai": "*"
  },
  "peerDependenciesMeta": {
    "@weaveintel/provider-openai": {
      "optional": true
    },
    "@weaveintel/provider-anthropic": {
      "optional": true
    }
  },
  "license": "MIT"
}
