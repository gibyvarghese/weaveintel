{
  "name": "@weaveintel/live-agents-demo",
  "version": "0.1.0",
  "description": "Reference application for @weaveintel/live-agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "worker": "tsx src/worker.ts"
  },
  "dependencies": {
    "@weaveintel/core": "*",
    "@weaveintel/live-agents": "*",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@weaveintel/testing": "*"
  },
  "license": "MIT"
}
