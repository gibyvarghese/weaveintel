{
  "type": "module",
  "name": "weaveintel",
  "version": "1.0.0",
  "private": true,
  "description": "Protocol-first, capability-driven AI framework for TypeScript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gibyvarghese/weaveintel"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "clients/*"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "check:api-boundaries": "node scripts/validate-api-boundaries.mjs",
    "check:workspace-topology": "node scripts/validate-workspace-topology.mjs",
    "check:no-raw-fetch": "node scripts/check-no-raw-fetch.mjs",
    "check:no-adhoc-resilience": "node scripts/check-no-adhoc-resilience.mjs",
    "check:no-app-brand": "node scripts/check-no-app-brand.mjs",
    "check:vocab-w9": "node scripts/check-vocab-w9.mjs --w9-only",
    "test:examples": "tsc --noEmit --project tsconfig.examples.json",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"{packages,apps}/*/src/**/*.ts\"",
    "format:check": "prettier --check \"{packages,apps}/*/src/**/*.ts\"",
    "release:bump": "node scripts/bump-version.mjs",
    "release:tag": "node scripts/tag-release.mjs",
    "test:docs-samples": "node scripts/extract-docs-samples.mjs && tsc --noEmit -p tsconfig.docs-samples.json"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@changesets/cli": "^2.27.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.6",
    "dotenv": "^17.4.2",
    "openai": "^6.45.0",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "hono": "^4.12.25",
    "fast-uri": "^3.1.2",
    "fast-xml-builder": "^1.1.7",
    "qs": "^6.15.2",
    "vitest": "^3.2.6",
    "@vitest/mocker": "^3.2.6",
    "@vitest/coverage-v8": "$@vitest/coverage-v8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
